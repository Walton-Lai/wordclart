{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api/ws.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/ws",
      "dest": "api/ws.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
